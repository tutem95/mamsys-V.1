# Django
DJANGO_SETTINGS_MODULE=mamsys.settings.dev
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Database (django-tenants requires PostgreSQL)
DATABASE_URL=postgres://mamsys:mamsys@localhost:5432/mamsys

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Email (dev: console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@mamsys.local

# Multi-tenancy
TENANT_BASE_DOMAIN=localhost

# Sentry (opcional, solo prod)
# SENTRY_DSN=
